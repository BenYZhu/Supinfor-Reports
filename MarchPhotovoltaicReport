<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>2026年3月 光伏光能行业情报月报</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;600;700&family=Fira+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --primary: #1E40AF;
  --secondary: #3B82F6;
  --accent: #D97706;
  --bg: #F8FAFC;
  --fg: #1E3A8A;
  --muted: #E9EEF6;
  --border: #DBEAFE;
  --destructive: #DC2626;
  --success: #16A34A;
  --white: #FFFFFF;
  --sidebar-w: 280px;
}

html { scroll-behavior: smooth; }

body {
  font-family: 'Fira Sans', system-ui, -apple-system, sans-serif;
  background: var(--bg);
  color: var(--fg);
  line-height: 1.7;
  font-size: 15px;
}

/* ── Sidebar ── */
.sidebar {
  position: fixed;
  top: 0; left: 0;
  width: var(--sidebar-w);
  height: 100vh;
  background: linear-gradient(180deg, #0F2557 0%, var(--primary) 100%);
  color: #fff;
  overflow-y: auto;
  z-index: 100;
  padding: 24px 0;
  scrollbar-width: thin;
  scrollbar-color: rgba(255,255,255,.2) transparent;
}
.sidebar::-webkit-scrollbar { width: 4px; }
.sidebar::-webkit-scrollbar-thumb { background: rgba(255,255,255,.2); border-radius: 2px; }

.sidebar-logo {
  padding: 0 20px 20px;
  border-bottom: 1px solid rgba(255,255,255,.12);
  margin-bottom: 16px;
}
.sidebar-logo .brand {
  font-family: 'Fira Code', monospace;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 1px;
  color: rgba(255,255,255,.7);
  text-transform: uppercase;
}
.sidebar-logo .report-title {
  font-family: 'Fira Code', monospace;
  font-size: 14px;
  font-weight: 700;
  margin-top: 8px;
  line-height: 1.5;
}

.nav-section { padding: 0 12px; }
.nav-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 12px;
  border-radius: 8px;
  text-decoration: none;
  color: rgba(255,255,255,.7);
  font-size: 13px;
  font-weight: 500;
  transition: all .2s;
  margin-bottom: 2px;
}
.nav-item:hover { background: rgba(255,255,255,.08); color: #fff; }
.nav-item.active { background: rgba(255,255,255,.15); color: #fff; }
.nav-icon {
  width: 28px; height: 28px;
  border-radius: 6px;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Fira Code', monospace;
  font-size: 11px;
  font-weight: 700;
  flex-shrink: 0;
  background: rgba(255,255,255,.1);
}
.nav-item.active .nav-icon { background: var(--accent); color: #fff; }

/* ── Main ── */
.main { margin-left: var(--sidebar-w); padding: 0; }

/* ── Hero ── */
.hero {
  background: linear-gradient(135deg, #0F2557 0%, var(--primary) 50%, #1E3A8A 100%);
  color: #fff;
  padding: 80px 60px 60px;
  position: relative;
  overflow: hidden;
}
.hero::before {
  content: '';
  position: absolute;
  top: -50%; right: -20%;
  width: 600px; height: 600px;
  background: radial-gradient(circle, rgba(217,119,6,.15) 0%, transparent 70%);
  border-radius: 50%;
}
.hero::after {
  content: '';
  position: absolute;
  bottom: -30%; left: -10%;
  width: 400px; height: 400px;
  background: radial-gradient(circle, rgba(59,130,246,.1) 0%, transparent 70%);
  border-radius: 50%;
}
.hero-content { position: relative; z-index: 1; max-width: 900px; }
.hero-badge {
  display: inline-block;
  background: rgba(217,119,6,.2);
  border: 1px solid rgba(217,119,6,.4);
  color: #FCD34D;
  font-family: 'Fira Code', monospace;
  font-size: 12px;
  font-weight: 600;
  padding: 4px 14px;
  border-radius: 20px;
  margin-bottom: 24px;
  letter-spacing: 1px;
}
.hero h1 {
  font-family: 'Fira Code', monospace;
  font-size: 36px;
  font-weight: 700;
  line-height: 1.3;
  margin-bottom: 12px;
}
.hero .subtitle {
  font-size: 18px;
  font-weight: 300;
  color: rgba(255,255,255,.8);
  margin-bottom: 32px;
}
.hero .author {
  font-family: 'Fira Code', monospace;
  font-size: 13px;
  color: rgba(255,255,255,.5);
  letter-spacing: 1px;
}

/* ── Content Area ── */
.content-area { max-width: 1000px; margin: 0 auto; padding: 40px 60px 80px; }

/* ── Section Header ── */
.section-header {
  display: flex;
  align-items: center;
  gap: 16px;
  margin: 56px 0 28px;
  padding-bottom: 16px;
  border-bottom: 2px solid var(--border);
}
.section-header:first-child { margin-top: 0; }
.section-num {
  width: 48px; height: 48px;
  background: var(--primary);
  color: #fff;
  border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Fira Code', monospace;
  font-size: 18px;
  font-weight: 700;
  flex-shrink: 0;
}
.section-header h2 {
  font-family: 'Fira Code', monospace;
  font-size: 22px;
  font-weight: 700;
  color: var(--primary);
}

/* ── Page Card ── */
.page-card {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 32px;
  margin-bottom: 24px;
  box-shadow: 0 1px 3px rgba(0,0,0,.04);
  transition: box-shadow .2s;
}
.page-card:hover { box-shadow: 0 4px 12px rgba(0,0,0,.08); }

.page-label {
  font-family: 'Fira Code', monospace;
  font-size: 11px;
  font-weight: 600;
  color: var(--secondary);
  letter-spacing: 1px;
  text-transform: uppercase;
  margin-bottom: 12px;
}

.page-card h3 {
  font-family: 'Fira Code', monospace;
  font-size: 17px;
  font-weight: 700;
  color: var(--fg);
  line-height: 1.5;
  margin-bottom: 20px;
  padding-bottom: 16px;
  border-bottom: 1px solid var(--border);
}

.insight-list { list-style: none; margin-bottom: 20px; }
.insight-list li {
  position: relative;
  padding: 8px 0 8px 24px;
  font-size: 14px;
  line-height: 1.7;
}
.insight-list li::before {
  content: '';
  position: absolute;
  left: 0; top: 16px;
  width: 8px; height: 8px;
  background: var(--secondary);
  border-radius: 50%;
}

.key-data {
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  border-left: 4px solid var(--accent);
  border-radius: 0 8px 8px 0;
  padding: 14px 20px;
  margin: 16px 0;
  font-size: 14px;
  font-weight: 500;
  color: #92400E;
}
.key-data::before {
  content: 'KEY DATA';
  display: block;
  font-family: 'Fira Code', monospace;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 1.5px;
  color: var(--accent);
  margin-bottom: 6px;
}

.insight-extend {
  background: var(--muted);
  border-radius: 8px;
  padding: 16px 20px;
  margin-top: 16px;
  font-size: 14px;
  font-style: italic;
  color: #475569;
  border-left: 3px solid var(--secondary);
}

/* ── Deep Insight Card ── */
.deep-insight {
  background: linear-gradient(135deg, #0F2557 0%, var(--primary) 100%);
  color: #fff;
  border-radius: 12px;
  padding: 36px;
  margin-bottom: 24px;
}
.deep-insight-label {
  font-family: 'Fira Code', monospace;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 2px;
  color: var(--accent);
  margin-bottom: 20px;
  text-transform: uppercase;
}
.deep-insight-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}
.deep-insight-item {
  background: rgba(255,255,255,.08);
  border-radius: 10px;
  padding: 20px;
  border: 1px solid rgba(255,255,255,.1);
}
.deep-insight-item .di-label {
  font-family: 'Fira Code', monospace;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 1px;
  margin-bottom: 10px;
  display: flex; align-items: center; gap: 8px;
}
.di-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}
.di-dot.trend { background: var(--accent); }
.di-dot.signal { background: var(--destructive); }
.di-dot.future { background: var(--success); }
.deep-insight-item p {
  font-size: 14px;
  line-height: 1.7;
  color: rgba(255,255,255,.85);
}

/* ── Executive Summary ── */
.exec-summary { margin-bottom: 20px; }
.exec-card {
  background: var(--white);
  border-radius: 12px;
  padding: 24px 28px;
  margin-bottom: 16px;
  display: flex;
  gap: 20px;
  align-items: flex-start;
  border: 1px solid var(--border);
  box-shadow: 0 1px 3px rgba(0,0,0,.04);
}
.exec-card:nth-child(1) { border-left: 5px solid var(--primary); }
.exec-card:nth-child(2) { border-left: 5px solid var(--accent); }
.exec-card:nth-child(3) { border-left: 5px solid var(--destructive); }
.exec-card:nth-child(4) { border-left: 5px solid var(--primary); }
.exec-card:nth-child(5) { border-left: 5px solid var(--accent); }
.exec-num {
  width: 40px; height: 40px;
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Fira Code', monospace;
  font-size: 16px;
  font-weight: 700;
  color: #fff;
  flex-shrink: 0;
}
.exec-card:nth-child(1) .exec-num { background: var(--primary); }
.exec-card:nth-child(2) .exec-num { background: var(--accent); }
.exec-card:nth-child(3) .exec-num { background: var(--destructive); }
.exec-card:nth-child(4) .exec-num { background: var(--primary); }
.exec-card:nth-child(5) .exec-num { background: var(--accent); }
.exec-card p {
  font-size: 14px;
  line-height: 1.7;
  font-weight: 500;
}

/* ── Strategy Section ── */
.strategy-card {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 28px 32px;
  margin-bottom: 20px;
  display: flex;
  gap: 24px;
  align-items: flex-start;
  box-shadow: 0 1px 3px rgba(0,0,0,.04);
}
.strategy-num {
  width: 52px; height: 52px;
  background: linear-gradient(135deg, var(--primary), var(--secondary));
  color: #fff;
  border-radius: 14px;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Fira Code', monospace;
  font-size: 22px;
  font-weight: 700;
  flex-shrink: 0;
}
.strategy-content { flex: 1; }
.strategy-badge {
  display: inline-block;
  background: var(--muted);
  color: var(--primary);
  font-family: 'Fira Code', monospace;
  font-size: 11px;
  font-weight: 600;
  padding: 3px 12px;
  border-radius: 20px;
  margin-bottom: 10px;
  letter-spacing: .5px;
}
.strategy-content p {
  font-size: 14px;
  line-height: 1.7;
}

/* ── Footer ── */
.footer {
  background: linear-gradient(135deg, #0F2557 0%, var(--primary) 100%);
  color: rgba(255,255,255,.6);
  text-align: center;
  padding: 40px 60px;
  font-size: 13px;
}
.footer .footer-brand {
  font-family: 'Fira Code', monospace;
  font-size: 14px;
  font-weight: 600;
  color: rgba(255,255,255,.9);
  margin-bottom: 8px;
}
.footer .footer-note {
  font-size: 12px;
  margin-top: 12px;
  color: rgba(255,255,255,.4);
}

/* ── KPI Dashboard ── */
.kpi-dashboard {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
  margin-bottom: 32px;
}
.kpi-card {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 24px 20px;
  text-align: center;
  box-shadow: 0 1px 3px rgba(0,0,0,.04);
  transition: transform .2s, box-shadow .2s;
  position: relative;
  overflow: hidden;
}
.kpi-card:hover { transform: translateY(-2px); box-shadow: 0 6px 16px rgba(0,0,0,.1); }
.kpi-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 4px;
}
.kpi-card:nth-child(1)::before { background: var(--primary); }
.kpi-card:nth-child(2)::before { background: var(--destructive); }
.kpi-card:nth-child(3)::before { background: var(--success); }
.kpi-card:nth-child(4)::before { background: var(--accent); }
.kpi-icon {
  width: 48px; height: 48px;
  border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 12px;
  font-size: 22px;
}
.kpi-card:nth-child(1) .kpi-icon { background: rgba(30,64,175,.1); color: var(--primary); }
.kpi-card:nth-child(2) .kpi-icon { background: rgba(220,38,38,.1); color: var(--destructive); }
.kpi-card:nth-child(3) .kpi-icon { background: rgba(22,163,74,.1); color: var(--success); }
.kpi-card:nth-child(4) .kpi-icon { background: rgba(217,119,6,.1); color: var(--accent); }
.kpi-value {
  font-family: 'Fira Code', monospace;
  font-size: 28px;
  font-weight: 700;
  margin-bottom: 4px;
}
.kpi-card:nth-child(1) .kpi-value { color: var(--primary); }
.kpi-card:nth-child(2) .kpi-value { color: var(--destructive); }
.kpi-card:nth-child(3) .kpi-value { color: var(--success); }
.kpi-card:nth-child(4) .kpi-value { color: var(--accent); }
.kpi-label {
  font-size: 13px;
  color: #64748B;
  font-weight: 500;
}
.kpi-sub {
  font-family: 'Fira Code', monospace;
  font-size: 11px;
  color: #94A3B8;
  margin-top: 6px;
}

/* ── Data Tables ── */
.viz-table-wrap {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 28px 32px;
  margin-bottom: 24px;
  box-shadow: 0 1px 3px rgba(0,0,0,.04);
}
.viz-table-title {
  font-family: 'Fira Code', monospace;
  font-size: 14px;
  font-weight: 700;
  color: var(--primary);
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.viz-table-title::before {
  content: '';
  width: 4px; height: 18px;
  background: var(--primary);
  border-radius: 2px;
}
.viz-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 13px;
}
.viz-table thead th {
  background: linear-gradient(135deg, #0F2557, var(--primary));
  color: #fff;
  font-family: 'Fira Code', monospace;
  font-size: 12px;
  font-weight: 600;
  padding: 12px 16px;
  text-align: left;
  letter-spacing: .5px;
}
.viz-table thead th:first-child { border-radius: 8px 0 0 0; }
.viz-table thead th:last-child { border-radius: 0 8px 0 0; }
.viz-table tbody td {
  padding: 11px 16px;
  border-bottom: 1px solid var(--border);
  font-size: 13px;
}
.viz-table tbody tr:nth-child(even) { background: #F8FAFC; }
.viz-table tbody tr:hover { background: #EFF6FF; }
.viz-table .num { font-family: 'Fira Code', monospace; font-weight: 600; }
.viz-table .highlight { color: var(--destructive); font-weight: 600; }
.viz-table .positive { color: var(--success); font-weight: 600; }

/* ── CSS Bar Chart (Horizontal) ── */
.bar-chart-wrap {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 28px 32px;
  margin-bottom: 24px;
  box-shadow: 0 1px 3px rgba(0,0,0,.04);
}
.bar-chart-title {
  font-family: 'Fira Code', monospace;
  font-size: 14px;
  font-weight: 700;
  color: var(--primary);
  margin-bottom: 20px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.bar-chart-title::before {
  content: '';
  width: 4px; height: 18px;
  background: var(--accent);
  border-radius: 2px;
}
.bar-item {
  display: flex;
  align-items: center;
  margin-bottom: 14px;
  gap: 12px;
}
.bar-label {
  width: 100px;
  font-family: 'Fira Code', monospace;
  font-size: 12px;
  font-weight: 600;
  color: var(--fg);
  text-align: right;
  flex-shrink: 0;
}
.bar-track {
  flex: 1;
  height: 28px;
  background: var(--muted);
  border-radius: 6px;
  overflow: hidden;
  position: relative;
}
.bar-fill {
  height: 100%;
  border-radius: 6px;
  display: flex;
  align-items: center;
  padding-left: 10px;
  transition: width .8s ease;
  position: relative;
}
.bar-fill-primary { background: linear-gradient(90deg, var(--primary), var(--secondary)); }
.bar-fill-accent { background: linear-gradient(90deg, var(--accent), #F59E0B); }
.bar-fill-success { background: linear-gradient(90deg, var(--success), #22C55E); }
.bar-fill-destructive { background: linear-gradient(90deg, var(--destructive), #EF4444); }
.bar-fill-purple { background: linear-gradient(90deg, #7C3AED, #A78BFA); }
.bar-val {
  font-family: 'Fira Code', monospace;
  font-size: 11px;
  font-weight: 600;
  color: #fff;
  white-space: nowrap;
}
.bar-val-outside {
  font-family: 'Fira Code', monospace;
  font-size: 11px;
  font-weight: 600;
  color: var(--fg);
  margin-left: 8px;
  white-space: nowrap;
  flex-shrink: 0;
}

/* ── CSS Column Chart ── */
.col-chart-wrap {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 28px 32px;
  margin-bottom: 24px;
  box-shadow: 0 1px 3px rgba(0,0,0,.04);
}
.col-chart-title {
  font-family: 'Fira Code', monospace;
  font-size: 14px;
  font-weight: 700;
  color: var(--primary);
  margin-bottom: 24px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.col-chart-title::before {
  content: '';
  width: 4px; height: 18px;
  background: var(--destructive);
  border-radius: 2px;
}
.col-chart {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 48px;
  height: 240px;
  padding: 0 40px;
  border-bottom: 2px solid var(--border);
  margin-bottom: 16px;
  position: relative;
}
.col-group {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}
.col-bar {
  width: 80px;
  border-radius: 8px 8px 0 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding-top: 10px;
  transition: height .8s ease;
  position: relative;
}
.col-bar-2024 { background: linear-gradient(180deg, var(--secondary), var(--primary)); }
.col-bar-2025 { background: linear-gradient(180deg, #EF4444, var(--destructive)); }
.col-bar-val {
  font-family: 'Fira Code', monospace;
  font-size: 14px;
  font-weight: 700;
  color: #fff;
}
.col-bar-label {
  font-family: 'Fira Code', monospace;
  font-size: 12px;
  font-weight: 600;
  color: var(--fg);
  margin-top: 8px;
}
.col-chart-badge {
  display: inline-block;
  background: rgba(220,38,38,.1);
  color: var(--destructive);
  font-family: 'Fira Code', monospace;
  font-size: 13px;
  font-weight: 700;
  padding: 6px 16px;
  border-radius: 20px;
  text-align: center;
  margin-top: 8px;
}

/* ── Timeline ── */
.timeline-wrap {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 28px 32px;
  margin-bottom: 24px;
  box-shadow: 0 1px 3px rgba(0,0,0,.04);
}
.timeline-title {
  font-family: 'Fira Code', monospace;
  font-size: 14px;
  font-weight: 700;
  color: var(--primary);
  margin-bottom: 24px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.timeline-title::before {
  content: '';
  width: 4px; height: 18px;
  background: var(--secondary);
  border-radius: 2px;
}
.timeline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  padding: 20px 0;
}
.timeline::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 40px; right: 40px;
  height: 3px;
  background: linear-gradient(90deg, var(--primary), var(--accent), var(--destructive));
  transform: translateY(-50%);
  border-radius: 2px;
}
.timeline-node {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 1;
  flex: 1;
}
.timeline-dot {
  width: 20px; height: 20px;
  border-radius: 50%;
  border: 3px solid #fff;
